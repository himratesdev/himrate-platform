# HimRate — Environment Variables
# Copy to .env: cp .env.example .env

# Database
POSTGRES_USER=himrate
POSTGRES_PASSWORD=himrate_dev
POSTGRES_DB=himrate_development

# Redis
REDIS_URL=redis://redis:6379/0

# TASK-039 Phase C1: Trends cache Redis pool tuning (optional, sensible defaults).
# TRENDS_REDIS_POOL_SIZE — concurrent connections для cache metadata (epoch INCR/GET).
#   Default 25 = Sidekiq concurrency (10) + Puma max_threads (16). Bump если observed
#   connection waits в ConnectionPool::TimeoutError.
# TRENDS_REDIS_POOL_TIMEOUT — seconds wait при pool exhausted до raise TimeoutError.
#   Default 5 aligns с net_http defaults, SRS §8.3 reliability expectations.
# TRENDS_REDIS_POOL_SIZE=25
# TRENDS_REDIS_POOL_TIMEOUT=5

# Rails
RAILS_ENV=development
RAILS_LOG_TO_STDOUT=true

# Twitch OAuth (get from https://dev.twitch.tv/console)
TWITCH_CLIENT_ID=your_client_id
TWITCH_CLIENT_SECRET=your_client_secret
TWITCH_REDIRECT_URI=http://localhost:3000/api/v1/auth/twitch/callback

# Google OAuth (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback

# BUG-027: extra OAuth redirect_uris (comma-separated) beyond the web-callback
# defaults above — e.g. the extension's chrome.identity.getRedirectURL():
# https://<ext-id>.chromiumapp.org/ . Empty is fine for local web-only dev.
OAUTH_ALLOWED_REDIRECT_URIS=

# JWT
JWT_SECRET=your_jwt_secret_here

# Active Record Encryption (for AuthProvider.encrypts)
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=dev_primary_key_at_least_12_bytes
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=dev_deterministic_key_12bytes
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=dev_key_derivation_salt_val

# TASK-090 OQ-4 / SRS FR-019: MAINTENANCE_MODE — graceful deploy/downtime middleware.
# When ACTIVE=true, ALL /api/v1/* requests return HTTP 503 + JSON
# {maintenance:true, error:"MAINTENANCE_MODE", until, until_unix,
#  retry_after_seconds, retry_after_minutes, message}.
# Excluded paths: /api/v1/health/* (frontend polling) + /up (Rails health check).
# See docs/operations/maintenance-mode.md for the operations runbook.
# MAINTENANCE_MODE_ACTIVE=false
# MAINTENANCE_MODE_UNTIL=<ISO8601 end-of-window, e.g. 2026-06-01T12:00:00Z>
# Generic message override (used for any locale without a locale-specific override):
# MAINTENANCE_MODE_MESSAGE="Системные работы. Возвращаемся скоро."
# Locale-specific overrides (win over MAINTENANCE_MODE_MESSAGE):
# MAINTENANCE_MODE_MESSAGE_EN="Scheduled maintenance. Back shortly."
# MAINTENANCE_MODE_MESSAGE_RU="Системные работы. Возвращаемся скоро."
