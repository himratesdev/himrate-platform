<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for(:title) || "HimRate" %></title>
    <meta name="description" content="<%= content_for(:description) %>">
    <link rel="canonical" href="<%= canonical_url %>">
    <link rel="icon" type="image/svg+xml" href="<%= asset_path("brand/favicon.svg") %>">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="HimRate">
    <meta property="og:title" content="<%= content_for(:title) || "HimRate" %>">
    <meta property="og:url" content="<%= canonical_url %>">
    <meta property="og:locale" content="ru_RU">

    <% if analytics_enabled? %><%= javascript_include_tag "landing/analytics", async: true %><% end %>

    <style>
      *, ::before, ::after { box-sizing: border-box; }
      body { margin: 0; background: #07070C; color: #E7E7EE;
             font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
             line-height: 1.65; }
      .legal-wrap { max-width: 760px; margin: 0 auto; padding: 40px 20px 80px; }
      .legal-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 40px; }
      .legal-top img { height: 28px; }
      .legal-wrap h1 { font-size: 30px; line-height: 1.2; margin: 0 0 8px; }
      .legal-wrap h2 { font-size: 20px; margin: 36px 0 12px; color: #fff; }
      .legal-wrap p, .legal-wrap li { color: #C3C3CE; font-size: 15px; }
      .legal-wrap ul { padding-left: 20px; }
      .legal-wrap a { color: #FF5C8A; }
      .legal-meta { color: #7C7C88; font-size: 13px; margin-bottom: 8px; }
      .legal-foot { margin-top: 64px; padding-top: 24px; border-top: 1px solid #FFFFFF1A;
                    display: flex; flex-wrap: wrap; gap: 8px 20px; font-size: 14px; }
      .legal-foot a { color: #A8A8B4; text-decoration: none; }
      .legal-foot a:hover { color: #fff; }
    </style>
  </head>
  <body>
    <div class="legal-wrap">
      <div class="legal-top">
        <a href="/"><%= image_tag "brand/logo-horizontal-coral.svg", alt: "HimRate" %></a>
      </div>

      <%= yield %>

      <nav class="legal-foot" aria-label="Footer">
        <a href="/">Главная</a>
        <a href="/streamers">Стримерам</a>
        <a href="/brands">Брендам</a>
        <a href="/viewers">Зрителям</a>
        <a href="/methodology">Методология</a>
        <a href="/privacy">Конфиденциальность</a>
        <a href="/terms">Условия</a>
      </nav>
    </div>
  </body>
</html>
