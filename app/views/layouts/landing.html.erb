<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for(:title) || "HimRate" %></title>
    <meta name="description" content="<%= content_for(:description) %>">

    <%# Self-referencing canonical on the apex host consolidates www/http/staging
        duplicates onto https://himrate.com (TASK-060 SEO). LK app shells and the
        login page carry no public value → noindex (still `follow` so equity flows). %>
    <link rel="canonical" href="<%= canonical_url %>">
    <% if @brand_dashboard || @page == "login" %>
      <meta name="robots" content="noindex, follow">
    <% end %>

    <link rel="icon" type="image/svg+xml" href="<%= asset_path("brand/favicon.svg") %>">

    <meta property="og:type" content="website">
    <meta property="og:site_name" content="HimRate">
    <meta property="og:title" content="<%= content_for(:title) || "HimRate" %>">
    <meta property="og:description" content="<%= content_for(:description) %>">
    <meta property="og:url" content="<%= canonical_url %>">
    <meta property="og:image" content="<%= canonical_asset_url("brand/logo-square-gradient.svg") %>">
    <meta property="og:locale" content="ru_RU">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for(:title) || "HimRate" %>">
    <meta name="twitter:description" content="<%= content_for(:description) %>">

    <%# Export reset + FOUC guard. The export's static decorative dot field
        ([data-pencil-name="Dot BG"]) is stripped from the markup at render time, so
        the animated dot canvas (hr-shared.js on the inner pages, index.js on the
        home page) is the only background. Paint the dark bg up front so there is no
        flash before the canvas initialises. %>
    <style>
      *, ::before, ::after { box-sizing: border-box; }
      body { margin: 0; }
      html, body { background: #07070C; }
      /* Safety net: the fluid layout fits the viewport at every width, but the
         animated marquee / canvas background paint beyond it by design — clip any
         horizontal bleed so phones never get a stray sideways scroll. */
      html, body { overflow-x: hidden; max-width: 100%; }
    </style>

    <%= stylesheet_link_tag "landing_fonts" %>
    <%= stylesheet_link_tag "tailwind" %>
  </head>
  <body>
    <%= yield %>

    <%# The export's vanilla JS, served as CSP-safe external assets. index.html was
        self-contained in the export (its own canvas bg + nav live in index.js), so
        it does NOT also load hr-shared.js — that would double the canvas/nav. The
        other pages share hr-shared.js. hr-i18n.js (client RU/EN) loads on all. %>
    <% if @page %><%= javascript_include_tag "landing/#{@page}" %><% end %>
    <%# Shared brand-dashboard chrome (sidebar nav + topbar + logout) on the brand LK pages. %>
    <% if @brand_dashboard %><%= javascript_include_tag "landing/brand_nav" %><% end %>
    <%= javascript_include_tag "landing/hr-i18n" %>
    <% unless @page == "index" %><%= javascript_include_tag "landing/hr-shared" %><% end %>
    <%# Responsive header burger — every page, including the self-contained index. %>
    <%= javascript_include_tag "landing/mobile-nav" %>
  </body>
</html>
