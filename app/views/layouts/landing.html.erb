<!DOCTYPE html>
<html lang="ru">
  <head>
    <%= render "layouts/head_shared" %>

    <title><%= content_for(:title) || "HimRate" %></title>
    <meta name="description" content="<%= content_for(:description) %>">

    <%# Self-referencing canonical on the apex host consolidates www/http/staging duplicates onto
        https://himrate.com (TASK-060 SEO). The landing layout serves ONLY public, indexable surfaces
        (marketing pages + the public channel card /c/:login). The product UI (login + /app/*) lives on
        the `app` layout (noindex) — see PagesController#resolve_layout. %>
    <link rel="canonical" href="<%= canonical_url %>">

    <meta property="og:type" content="website">
    <meta property="og:site_name" content="HimRate">
    <meta property="og:title" content="<%= content_for(:title) || "HimRate" %>">
    <meta property="og:description" content="<%= content_for(:description) %>">
    <meta property="og:url" content="<%= canonical_url %>">
    <%# Per-page share image: a page sets content_for(:og_image) with an absolute URL
        (static PNG per page, or the dynamic /og/c/:login.png channel card). Falls back
        to the brand mark. Only custom PNGs get the 1200x630 dimension hints. %>
    <% og_image = content_for(:og_image) || canonical_asset_url("brand/logo-square-gradient.svg") %>
    <meta property="og:image" content="<%= og_image %>">
    <% if content_for?(:og_image) %>
      <meta property="og:image:width" content="1200">
      <meta property="og:image:height" content="630">
    <% end %>
    <meta property="og:locale" content="ru_RU">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for(:title) || "HimRate" %>">
    <meta name="twitter:description" content="<%= content_for(:description) %>">
    <meta name="twitter:image" content="<%= og_image %>">

    <%# Structured data (Organization + WebSite) — helps Google understand the brand
        and enables rich results / sitelinks. Not executable JS (type=ld+json) → CSP
        and the no-inline-<script> convention are unaffected. (TASK-060 SEO) %>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Organization",
            "@id": "<%= canonical_host %>/#organization",
            "name": "HimRate",
            "url": "<%= canonical_host %>/",
            "logo": "<%= canonical_asset_url("brand/logo-square-gradient.svg") %>",
            "description": "Аналитика реальности аудитории Twitch: Trust Index, ERV и репутация стримеров."
          },
          {
            "@type": "WebSite",
            "@id": "<%= canonical_host %>/#website",
            "url": "<%= canonical_host %>/",
            "name": "HimRate",
            "publisher": { "@id": "<%= canonical_host %>/#organization" },
            "inLanguage": "ru"
          }
        ]
      }
    </script>

    <%# Analytics (Metrika + GA4) — externalised (CSP-clean) and only on the
        canonical production host so staging / localhost don't pollute stats. %>
    <% if analytics_enabled? %><%= javascript_include_tag "landing/analytics", async: true %><% end %>
  </head>
  <body>
    <% if analytics_enabled? %>
      <noscript><div><img src="https://mc.yandex.ru/watch/110889452" style="position:absolute; left:-9999px;" alt=""></div></noscript>
    <% end %>
    <%= yield %>

    <%# The export's vanilla JS, served as CSP-safe external assets. index.html was self-contained in
        the export (its own canvas bg + nav live in index.js), so it does NOT also load hr-shared.js.
        hr-i18n.js (client RU/EN) loads on every landing page. %>
    <% if @page %><%= javascript_include_tag "landing/#{@page}" %><% end %>
    <%= javascript_include_tag "landing/hr-i18n" %>
    <%# hr-shared.js = the marketing nav + animated dot canvas. Skipped on index (self-contained bundle)
        and on the public channel card (/c/:login — it has its own chrome, and hr-shared's nav-wiring
        would hijack its buttons). The product UI never reaches this layout at all (app layout). %>
    <% unless @page.in?(%w[index channel_card]) %><%= javascript_include_tag "landing/hr-shared" %><% end %>
    <%# Responsive header burger — every landing page, including the self-contained index. %>
    <%= javascript_include_tag "landing/mobile-nav" %>
  </body>
</html>
