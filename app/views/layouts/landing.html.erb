<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for(:title) || "HimRate" %></title>
    <meta name="description" content="<%= content_for(:description) %>">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="HimRate">
    <meta property="og:title" content="<%= content_for(:title) || "HimRate" %>">
    <meta property="og:description" content="<%= content_for(:description) %>">
    <meta property="og:locale" content="ru_RU">
    <meta name="twitter:card" content="summary_large_image">

    <%# Export reset + FOUC guard. The export's static decorative dot field
        ([data-pencil-name="Dot BG"]) is stripped from the markup at render time, so
        the animated dot canvas (hr-shared.js on the inner pages, index.js on the
        home page) is the only background. Paint the dark bg up front so there is no
        flash before the canvas initialises. %>
    <style>
      *, ::before, ::after { box-sizing: border-box; }
      body { margin: 0; }
      html, body { background: #07070C; }
    </style>

    <%= stylesheet_link_tag "landing_fonts" %>
    <%= stylesheet_link_tag "tailwind" %>
    <%# Mobile layer framework (designer's export-1-mobile). Class/`.app`-scoped, so
        it never touches the desktop layer; only the `.app` mobile block uses it. %>
    <%= stylesheet_link_tag "m-shared" %>
  </head>
  <body>
    <%= yield %>

    <%# Two responsive layers, gated by viewport so only one runs:
        • Desktop (≥lg): per-page JS + hr-shared (index is self-contained → its own JS).
          Their #hr-bgfx canvas is gated to ≥1024 so it never double-paints on phones.
        • Mobile (<lg): m-shared.js drives the designer's .app layer (own #bgfx canvas,
          burger, reveals). m-i18n extends HR_TRANS with mobile copy.
        hr-i18n (base RU↔EN map) + mobile-nav (window.__hrSetLang fallback for pages
        without hr-shared, e.g. index) load on all. %>
    <% if @page %><%= javascript_include_tag "landing/#{@page}" %><% end %>
    <%= javascript_include_tag "landing/hr-i18n" %>
    <%= javascript_include_tag "landing/m-i18n" %>
    <% unless @page == "index" %><%= javascript_include_tag "landing/hr-shared" %><% end %>
    <%= javascript_include_tag "landing/m-shared" %>
    <%= javascript_include_tag "landing/mobile-nav" %>
  </body>
</html>
