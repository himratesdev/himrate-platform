<style id="hr-responsive">
  /* ===== RESPONSIVE LAYOUT (added) — layout only; motion/engine untouched ===== */
  [data-pencil-name="Стримерам"]{ width:100% !important; max-width:1440px !important; margin-left:auto !important; margin-right:auto !important; }

  .hr-burger{ display:none; }
  .hr-mnav{ position:fixed; inset:0; z-index:80; background:rgba(7,7,12,.97); -webkit-backdrop-filter:blur(10px); backdrop-filter:blur(10px); display:flex; flex-direction:column; padding:88px 22px 28px; gap:2px; opacity:0; transform:translateY(-10px); pointer-events:none; transition:opacity .25s, transform .25s; }
  .hr-mnav.open{ opacity:1; transform:none; pointer-events:auto; }
  .hr-mnav a{ display:flex; justify-content:space-between; align-items:center; padding:16px 4px; border-bottom:1px solid rgba(255,255,255,.09); color:#F5F2EC; text-decoration:none; font:600 19px/1 'Geist',system-ui,sans-serif; }
  .hr-mnav a span{ color:#8E8A9A; font:500 13px 'Geist Mono',monospace; }
  .hr-mnav a.cta{ margin-top:18px; justify-content:center; background:#7C3AED; border-radius:11px; border-bottom:none; color:#fff; padding:17px; }
  .hr-mlang{ display:flex; gap:8px; margin-top:16px; }
  .hr-mlang button{ flex:1; padding:12px; border:1px solid rgba(255,255,255,.16); border-radius:9px; background:transparent; color:#8E8A9A; font:600 13px 'Geist Mono',monospace; cursor:pointer; }

  @media (max-width:1080px){
    [data-pencil-name="Стримерам"] *{ max-width:100% !important; }
    [data-pencil-name="Strip"]{ max-width:none !important; }
    [data-pencil-name="L1"],[data-pencil-name="L2"],[data-pencil-name="L3"],[data-pencil-name="Headline"],
    [data-pencil-name="Heading"],[data-pencil-name="H"],[data-pencil-name="h"],[data-pencil-name="Sub"],
    [data-pencil-name="sub"],[data-pencil-name="Subhead"],[data-pencil-name="Подзаголовок"],[data-pencil-name="title"],
    [data-pencil-name="Body"],[data-pencil-name="intro"],[data-pencil-name="s"],[data-pencil-name="Link"]{ white-space:normal !important; }
    [data-pencil-name="Header"],
    [data-pencil-name="C0 Простыми словами"],
    [data-pencil-name="C1 Hero"],
    [data-pencil-name="C2 Главное"],
    [data-pencil-name="C2b · Биржа сделок"],
    [data-pencil-name="C3 · Выбор игры"],
    [data-pencil-name="C4 · Транскрипция и нарезки"],
    [data-pencil-name="C8 · Тарифы"],
    [data-pencil-name="C9 · Финальный CTA"],
    [data-pencil-name="Подвал"]{ padding-left:32px !important; padding-right:32px !important; }
    [data-pencil-name="Header"]{ padding-left:28px !important; padding-right:28px !important; }
  }

  /* header → burger ≤1024 */
  @media (max-width:1024px){
    [data-pencil-name="Menu"]{ display:none !important; }
    [data-pencil-name="Actions"]{ display:none !important; }
    .hr-burger{ display:flex !important; flex-direction:column; gap:5px; width:42px; height:42px; align-items:center; justify-content:center; border:1px solid rgba(255,255,255,.18); border-radius:9px; background:#0D0B14; cursor:pointer; }
    .hr-burger span{ width:18px; height:2px; background:#F5F2EC; border-radius:2px; transition:transform .25s, opacity .2s; }
    .hr-burger.x span:nth-child(1){ transform:translateY(7px) rotate(45deg); }
    .hr-burger.x span:nth-child(2){ opacity:0; }
    .hr-burger.x span:nth-child(3){ transform:translateY(-7px) rotate(-45deg); }
  }

  @media (max-width:900px){
    [data-pencil-name="Header"]{ padding-left:18px !important; padding-right:18px !important; }
    [data-pencil-name="Header"],
    [data-pencil-name="C0 Простыми словами"],
    [data-pencil-name="C1 Hero"],
    [data-pencil-name="C2 Главное"],
    [data-pencil-name="C2b · Биржа сделок"],
    [data-pencil-name="C3 · Выбор игры"],
    [data-pencil-name="C4 · Транскрипция и нарезки"],
    [data-pencil-name="C8 · Тарифы"],
    [data-pencil-name="C9 · Финальный CTA"],
    [data-pencil-name="Подвал"]{ padding-left:18px !important; padding-right:18px !important; }
    /* stack card-grid rows */
    [data-pencil-name="C0 Простыми словами"],
    [data-pencil-name="Row1"],
    [data-pencil-name="legend"],
    [data-pencil-name="Row2"],
    [data-pencil-name="stats"],
    [data-pencil-name="Board"],
    [data-pencil-name="Deal"],
    [data-pencil-name="Брендам плашки"],
    [data-pencil-name="Игры‑примеры"],
    [data-pencil-name="metrics"],
    [data-pencil-name="Подсказка"],
    [data-pencil-name="Bento"],
    [data-pencil-name="Plans"],
    [data-pencil-name="Подвал"],
    [data-pencil-name="Подвал"]{ flex-direction:column !important; height:auto !important; align-items:stretch !important; }
    [data-pencil-name="C0 Простыми словами"] > *,
    [data-pencil-name="Row1"] > *,
    [data-pencil-name="legend"] > *,
    [data-pencil-name="Row2"] > *,
    [data-pencil-name="stats"] > *,
    [data-pencil-name="Board"] > *,
    [data-pencil-name="Deal"] > *,
    [data-pencil-name="Брендам плашки"] > *,
    [data-pencil-name="Игры‑примеры"] > *,
    [data-pencil-name="metrics"] > *,
    [data-pencil-name="Подсказка"] > *,
    [data-pencil-name="Bento"] > *,
    [data-pencil-name="Plans"] > *,
    [data-pencil-name="Подвал"] > *,
    [data-pencil-name="Подвал"] > *{ width:100% !important; height:auto !important; min-height:0 !important; align-self:stretch !important; }
    /* footer columns + button rows wrap */
    [data-pencil-name="Columns"],[data-pencil-name="Cols"]{ flex-wrap:wrap !important; gap:26px 40px !important; width:100% !important; }
    [data-pencil-name="Buttons"],[data-pencil-name="CTAs"],[data-pencil-name="CTA Row"],[data-pencil-name="Buttons Row"]{ flex-wrap:wrap !important; justify-content:center !important; width:100% !important; }
  }

  /* TABLET-REFINE: 721-900 stays single-column but with tablet (not phone) spacing */
  @media (min-width:721px) and (max-width:900px){
    [data-pencil-name="Header"],
    [data-pencil-name="Header"],
    [data-pencil-name="C1 Hero"],
    [data-pencil-name="C0 Простыми словами"],
    [data-pencil-name="C2 Главное"],
    [data-pencil-name="C2b · Биржа сделок"],
    [data-pencil-name="C3 · Выбор игры"],
    [data-pencil-name="C4 · Транскрипция и нарезки"],
    [data-pencil-name="C8 · Тарифы"],
    [data-pencil-name="C9 · Финальный CTA"],
    [data-pencil-name="Подвал"]{ padding-left:30px !important; padding-right:30px !important; }
    [data-pencil-name="L1"],[data-pencil-name="L2"],[data-pencil-name="L3"]{ font-size:42px !important; line-height:1.08 !important; }
  }
</style>
