<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
<% @urls.each do |loc| %>
  <url>
    <loc><%= loc %></loc>
    <changefreq>weekly</changefreq>
    <priority><%= loc.end_with?("himrate.com/") ? "1.0" : "0.8" %></priority>
  </url>
<% end %>
</urlset>
