#!/bin/bash -e

# If running the rails server then create or migrate existing database
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare

  # TASK-251.14b: provision the ClickHouse analytics schema (chat_messages + MVs) on the web role,
  # since the deploy path is `kamal deploy` (no setup hook) and live IRC chat ingest needs the
  # tables to exist. Idempotent (CREATE … IF NOT EXISTS). Guarded + time-boxed + non-fatal:
  # only when CLICKHOUSE_HOST is set, and a CH outage must NEVER block web boot. `|| echo` keeps
  # `set -e` from aborting. Post PR 1e-B (chat_messages PG table dropped, ClickHouse is sole SoT),
  # this step is critical-path for chat persistence on first deploy — without it, ChatMessageWorker
  # would silently lose inserts. PG chat_messages no longer exists as a fallback.
  if [ -n "${CLICKHOUSE_HOST}" ]; then
    timeout 30 ./bin/rails clickhouse:setup || echo "WARN: clickhouse:setup skipped/failed (CH unreachable?) — non-fatal, retry next boot"
  fi
fi

exec "${@}"
