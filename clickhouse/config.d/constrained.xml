<?xml version="1.0"?>
<!--
  TASK-251.14: ClickHouse config for HOSTKEY (8 vCPU / 32 GiB / NVMe). CH coexists with
  Postgres (4 GiB shared_buffers) on the box; right-sized post-migration to a 6 GiB RAM cap
  (raised from the 1.2 GiB Time4VPS-era value). CH offloads PG's chat re-scans onto columnar
  storage, so the net box effect stays favorable.

  Networking: listen on the container interface so app containers reach CH over the Kamal
  Docker network by DNS name (himrate-clickhouse). The host port is bound to 127.0.0.1 only
  (config/deploy.yml) and the default user is password-protected (CLICKHOUSE_PASSWORD), so CH
  is not publicly reachable — same internal-only model as the db/redis accessories.
-->
<clickhouse>
    <listen_host>0.0.0.0</listen_host>

    <!-- TASK-251.14b: pin the server timezone to UTC. DateTime64 columns without an explicit tz are
         parsed/rendered in the server tz; the dual-write sends naive UTC timestamp strings and the MVs
         bucket by toStartOfMinute, so an explicit UTC removes any reliance on the image default and
         guarantees true 0-divergence vs Postgres (DEC-7) regardless of base-image changes. -->
    <timezone>UTC</timezone>

    <!-- Cap CH RAM under the 8g container limit (config/deploy.yml options.memory), leaving
         headroom for CH's off-heap caches + the PG/Rails co-tenants on the 32 GiB box. -->
    <max_server_memory_usage>6442450944</max_server_memory_usage>

    <!-- mark_cache 1 GiB — primary-key marks for fast lookups (CH default 5 GiB is sized for
         dedicated hosts; 1 GiB fits the 6 GiB cap while covering our partition count). -->
    <mark_cache_size>1073741824</mark_cache_size>
    <uncompressed_cache_size>0</uncompressed_cache_size>

    <!-- Log to stdout so `docker logs` captures CH logs (CH defaults to file logging under
         /var/log/clickhouse-server, which isn't mounted/shipped). Re-attaches to promtail → Loki
         if/when the observability tier is provisioned (EPIC SCALE ARCHITECTURE §2). -->
    <logger>
        <console>1</console>
        <!-- Drop the inherited file log targets so CH logs ONLY to stdout (→ promtail → Loki),
             not also to the unmounted, ephemeral /var/log/clickhouse-server. -->
        <log remove="remove"/>
        <errorlog remove="remove"/>
    </logger>

    <!-- ═══ System-log table retention (BUG-DISK-FULL, incident 2026-07-18) ═══
         CH's built-in observability tables are unbounded MergeTree by default. With no TTL they
         grew to ~139 GiB since the 2026-06-12 HOSTKEY migration (text_log 67 GiB +
         processors_profile_log 47 GiB + query_log 19 GiB + trace_log 4.6 GiB) and filled the
         236 GiB disk → Postgres could not write postmaster.pid ("No space left on device") →
         crash-loop → staging down ~6h. Our actual data (chat_messages 18 GiB, MVs ~1 GiB) was tiny.
         The <logger> block above disables CH's FILE logs, but those are the system LOG TABLES —
         a separate MergeTree store. We do not profile CH internals, so: disable the two largest
         pure-noise tables outright, and cap the rest at a short TTL. Applies to newly-created
         tables on CH restart; the existing 139 GiB was TRUNCATEd during incident remediation. -->
    <text_log remove="remove"/>              <!-- was 67 GiB — CH-internal text log, never queried -->
    <processors_profile_log remove="remove"/> <!-- was 47 GiB — query-processor profiling, never queried -->
    <query_log><ttl>event_date + INTERVAL 3 DAY DELETE</ttl></query_log>
    <trace_log><ttl>event_date + INTERVAL 3 DAY DELETE</ttl></trace_log>
    <metric_log><ttl>event_date + INTERVAL 3 DAY DELETE</ttl></metric_log>
    <asynchronous_metric_log><ttl>event_date + INTERVAL 3 DAY DELETE</ttl></asynchronous_metric_log>
    <part_log><ttl>event_date + INTERVAL 3 DAY DELETE</ttl></part_log>
    <query_views_log><ttl>event_date + INTERVAL 3 DAY DELETE</ttl></query_views_log>
</clickhouse>
